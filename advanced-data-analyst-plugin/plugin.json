{
  "id": "advanced_data_analyst",
  "uuid": "3e9b1d9c-f9e0-4965-a86f-22a39a7d8a9e",
  "emoji": "📊",
  "title": "Advanced Data & File Analyst",
  "userSettings": [
    {
      "name": "vercel_backend_url",
      "label": "Vercel Backend URL",
      "required": true,
      "description": "The base URL of the deployed Vercel app (e.g., https://my-backend.vercel.app)"
    },
    {
      "name": "e2b_api_key",
      "label": "E2B API Key",
      "type": "password",
      "required": true,
      "description": "Your E2B API Key"
    },
    {
      "name": "gemini_api_key",
      "label": "Gemini API Key",
      "type": "password",
      "required": true,
      "description": "Your Google Gemini API Key"
    }
  ],
  "pluginFunctions": [
    {
      "id": "get_file_to_sandbox",
      "name": "get_file_to_sandbox",
      "httpAction": {
        "url": "{vercel_backend_url}/api/get_file",
        "method": "POST",
        "hasBody": true,
        "hasHeaders": true,
        "requestBody": "{\n  \"file_url\": \"{file_url}\"\n}",
        "requestHeaders": "{\n  \"Content-Type\": \"application/json\",\n  \"X-E2B-Api-Key\": \"{e2b_api_key}\"\n}"
      },
      "openaiSpec": {
        "name": "get_file_to_sandbox",
        "parameters": {
          "type": "object",
          "required": [
            "file_url"
          ],
          "properties": {
            "file_url": {
              "type": "string",
              "description": "The URL of the file to download."
            }
          }
        },
        "description": "Takes a user-provided file URL (e.g., a shared Drive link, raw GitHub link, or standard web URL), spins up an E2B sandbox, and downloads the file into the sandbox. Returns a reference ID to access the sandbox/file in future steps, plus basic metadata (file name, size, estimated line/character count)."
      },
      "outputType": "respond_to_ai",
      "implementationType": "http"
    },
    {
      "id": "preview_file_contents",
      "name": "preview_file_contents",
      "httpAction": {
        "url": "{vercel_backend_url}/api/preview",
        "method": "POST",
        "hasBody": true,
        "hasHeaders": true,
        "requestBody": "{\n  \"sandbox_id\": \"{sandbox_id}\",\n  \"start_line\": {start_line},\n  \"end_line\": {end_line}\n}",
        "requestHeaders": "{\n  \"Content-Type\": \"application/json\",\n  \"X-E2B-Api-Key\": \"{e2b_api_key}\"\n}"
      },
      "openaiSpec": {
        "name": "preview_file_contents",
        "parameters": {
          "type": "object",
          "required": [
            "sandbox_id",
            "start_line",
            "end_line"
          ],
          "properties": {
            "sandbox_id": {
              "type": "string",
              "description": "The sandbox reference ID."
            },
            "start_line": {
              "type": "integer",
              "description": "The starting line number to preview (1-indexed)."
            },
            "end_line": {
              "type": "integer",
              "description": "The ending line number to preview."
            }
          }
        },
        "description": "Allows the primary model to peek at specific slices of the file to understand its structure without bloating the context window."
      },
      "outputType": "respond_to_ai",
      "implementationType": "http"
    },
    {
      "id": "execute_sandbox_code",
      "name": "execute_sandbox_code",
      "httpAction": {
        "url": "{vercel_backend_url}/api/execute",
        "method": "POST",
        "hasBody": true,
        "hasHeaders": true,
        "requestBody": "{\n  \"sandbox_id\": \"{sandbox_id}\",\n  \"code\": \"{code}\"\n}",
        "requestHeaders": "{\n  \"Content-Type\": \"application/json\",\n  \"X-E2B-Api-Key\": \"{e2b_api_key}\"\n}"
      },
      "openaiSpec": {
        "name": "execute_sandbox_code",
        "parameters": {
          "type": "object",
          "required": [
            "sandbox_id",
            "code"
          ],
          "properties": {
            "sandbox_id": {
              "type": "string",
              "description": "The sandbox reference ID."
            },
            "code": {
              "type": "string",
              "description": "The Python code to execute. Standard libraries like pandas, json, os can be imported."
            }
          }
        },
        "description": "General purpose Python code execution and file manipulation. The code runs in the E2B sandbox where the file is located."
      },
      "outputType": "respond_to_ai",
      "implementationType": "http"
    },
    {
      "id": "semantic_file_summary",
      "name": "semantic_file_summary",
      "httpAction": {
        "url": "{vercel_backend_url}/api/summary",
        "method": "POST",
        "hasBody": true,
        "hasHeaders": true,
        "requestBody": "{\n  \"sandbox_id\": \"{sandbox_id}\",\n  \"instruction\": \"{instruction}\"\n}",
        "requestHeaders": "{\n  \"Content-Type\": \"application/json\",\n  \"X-E2B-Api-Key\": \"{e2b_api_key}\",\n  \"X-Gemini-Api-Key\": \"{gemini_api_key}\"\n}"
      },
      "openaiSpec": {
        "name": "semantic_file_summary",
        "parameters": {
          "type": "object",
          "required": [
            "sandbox_id",
            "instruction"
          ],
          "properties": {
            "sandbox_id": {
              "type": "string",
              "description": "The sandbox reference ID."
            },
            "instruction": {
              "type": "string",
              "description": "A specific prompt/instruction from the primary model (e.g., 'Read this file and extract the top 5 user complaints')."
            }
          }
        },
        "description": "When Python code isn't enough (e.g., messy text, natural language analysis), the primary model can delegate the reading to a cheaper, high-context sub-agent."
      },
      "outputType": "respond_to_ai",
      "implementationType": "http"
    }
  ],
  "overviewMarkdown": "Advanced Data & File Analyst. Connects to a Vercel backend and E2B sandbox for remote code execution.",
  "authenticationType": "AUTH_TYPE_NONE"
}
